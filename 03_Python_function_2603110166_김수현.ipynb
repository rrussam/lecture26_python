   "source": [
    "def gugudan(dan) :\n",
    "    print(f'[구구단 {dan}단]')\n",
    "    for i in range(1, 10) :\n",
    "        print(f'{dan} x {i} = {dan * i}')\n",
    "\n",
    "dan = int(input('몇 단을 출력? :'))\n",
    "gugudan(dan)"
   ]
